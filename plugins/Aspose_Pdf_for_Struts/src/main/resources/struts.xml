<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
	"-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
	"http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<constant name="struts.action.extension" value="do" />
	<constant name="struts.enable.DynamicMethodInvocation" value="false" />

	<package name="books" namespace="/" extends="struts-default">
		<action name="showbooks" class="com.books.ShowBooks" method="execute">
			<result name="success">/jsp/books/books.jsp</result>
		</action>

		<action name="addbook" class="com.books.BookActions" method="addBook">
			<result name="success">/jsp/books/addbook.jsp</result>
		</action>

		<action name="editbook" class="com.books.BookActions" method="editBook">
			<result name="success">/jsp/books/editbook.jsp</result>
		</action>

		<action name="savebook" class="com.books.BookActions" method="saveBook">
			<result name="success" type="redirectAction">showbooks</result>
		</action>

		<action name="updatebook" class="com.books.BookActions" method="updateBook">
			<result name="success" type="redirectAction">showbooks</result>
		</action>

		<action name="deletebook" class="com.books.BookActions" method="deleteBook">
			<result name="success" type="redirectAction">showbooks</result>
		</action>

		<action name="exporttopdf" class="com.books.BookActions" method="exportToPdf" />
	</package>
</struts>
